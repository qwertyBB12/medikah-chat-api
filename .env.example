# Medikah Chat API - Environment Variables
# Copy this file to .env and fill in values

# ===========================================
# CORS (required for production)
# ===========================================
ALLOWED_ORIGINS=https://medikah.health,https://www.medikah.health

# ===========================================
# EMAIL NOTIFICATIONS (required - Resend)
# ===========================================
RESEND_API_KEY=re_xxxxxxxxxx
RESEND_SENDER_EMAIL=Medikah <noreply@medikah.health>
EMAIL_SANDBOX_MODE=false  # Set to true to skip actual email sending

# Doctor notification recipient
DOCTOR_NOTIFICATION_EMAIL=doctor@example.com

# ===========================================
# TELEMEDICINE (at least one required)
# ===========================================
# Option 1: Single shared room URL
DOXY_ROOM_URL=https://doxy.me/your-room

# Option 2: Base URL for unique per-appointment rooms
# DOXY_BASE_URL=https://doxy.me/medikah

# ===========================================
# APPOINTMENTS (required)
# ===========================================
# Security key - generate with: openssl rand -hex 32
APPOINTMENT_HASH_KEY=

# Duration in minutes (default: 30)
APPOINTMENT_DURATION_MINUTES=30

# Doctor display name shown to patients
ON_CALL_DOCTOR_NAME=Dr. Smith

# ===========================================
# AI FEATURES (optional)
# ===========================================
# OpenAI - for patient education summaries
OPENAI_API_KEY=

# ===========================================
# DATABASE (optional)
# ===========================================
# Supabase - falls back to in-memory if not set
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO

# =======================================================================
# Phase 11-12 — Práctikah workspace provisioning (FastAPI service)
# Do NOT commit real values. Populate in Render dashboard.
# =======================================================================

# --- Mailcow Admin API ---
# Rotate in Mailcow admin → Configuration → Access → API (current key returns 401 — D-23)
MAILCOW_API_URL=https://practikah.medikah.health
MAILCOW_API_KEY=

# --- NextAuth JWT verification (must match medikah-chat-frontend NEXTAUTH_SECRET) ---
NEXTAUTH_SECRET=

# --- Cloudflare (workspace provisioning: zone creation, DNS, CF for SaaS) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Supabase (already above; repeated here for clarity) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Internal FastAPI → Next.js email trigger (Phase 12-02) ---
# 32+ char random string; rotate quarterly.
# MUST match the INTERNAL_API_SHARED_SECRET value set in the Netlify dashboard.
# Generate with: openssl rand -base64 32
INTERNAL_API_SHARED_SECRET=

# --- Sandbox mode (Phase 11 D-19) ---
# Set to 'true' for staging dry-runs (sandbox-prefixes Mailcow domains, tags CF zones)
MEDIKAH_PROVISIONING_SANDBOX=false

# =======================================================================
# Phase 13 — Stripe billing (Pro upsell)
# Do NOT commit real values. Populate in Render dashboard.
# =======================================================================

# --- Stripe API ---
# Test-mode (sk_test_...) for staging, live-mode (sk_live_...) for production.
# Webhook handler imports this lazily; portal-link BFF reads it on each request.
STRIPE_SECRET_KEY=

# --- Stripe Webhook Signing Secret ---
# From `stripe listen` (dev) or Stripe Dashboard → Developers → Webhooks (prod).
# Used by services/practikah/stripe_webhook.py:verify_signature on the raw body
# (T-13-01-01 / T-13-01-02). NEVER expose to the Next.js client bundle.
STRIPE_WEBHOOK_SECRET=

# --- Stripe Customer Portal Configuration ID ---
# Output of scripts/seed_stripe_products.py — copy the bpc_... value.
# Optional; if unset, Stripe uses the account-default Portal configuration.
STRIPE_PORTAL_CONFIGURATION_ID=

# --- Frontend URL for Stripe return_url ---
# Used by /practikah/billing/portal-link to build the Customer Portal return URL.
# Falls back to NEXT_PUBLIC_BASE_URL, then https://medikah.health.
PRACTIKAH_FRONTEND_URL=

# --- Mexican SAT registration flag (D-05) ---
# When TRUE, Stripe Tax computes Mexican IVA (16%) on MXN customers and
# Práctikah issues CFDI invoices. Until SAT registration completes (operator
# carry-item), keep FALSE — invoices are not CFDI-compliant for MX customers.
MEDIKAH_MX_SAT_REGISTERED=false
